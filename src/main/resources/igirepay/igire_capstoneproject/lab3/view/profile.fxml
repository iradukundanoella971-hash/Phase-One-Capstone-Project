<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="igirepay.igire_capstoneproject.lab3.controller.ProfileController"
            styleClass="dashboard-root"
            prefWidth="440" prefHeight="720">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 24 12 24;">
            <Button text="← Back" onAction="#handleBack" styleClass="btn-link"/>
            <Label text="Profile" styleClass="page-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="dashboard-scroll" hbarPolicy="NEVER">
            <VBox spacing="16" style="-fx-padding: 0 24 24 24;">

                <VBox spacing="14" styleClass="card">
                    <Label text="Personal details" styleClass="section-title"/>
                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Full name" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="fullNameField" styleClass="form-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Email" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="emailField" styleClass="form-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Phone" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="phoneField" styleClass="form-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <VBox spacing="14" styleClass="card">
                    <Label text="Change PIN" styleClass="section-title"/>
                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Current PIN" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="currentPinField" styleClass="form-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="New PIN" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="newPinField" promptText="5 digits" styleClass="form-field"
                                        GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Confirm PIN" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="confirmPinField" styleClass="form-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

                <Button text="Save Changes" onAction="#handleUpdateProfile" styleClass="btn-primary" maxWidth="Infinity"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
