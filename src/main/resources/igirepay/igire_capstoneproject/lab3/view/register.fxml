<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="igirepay.igire_capstoneproject.lab3.controller.RegisterController"
           styleClass="app-background"
           prefWidth="440" prefHeight="720">

    <ScrollPane fitToWidth="true" styleClass="auth-scroll" hbarPolicy="NEVER">
        <VBox alignment="CENTER" spacing="0">
            <padding>
                <Insets top="32" right="24" bottom="32" left="24"/>
            </padding>

            <VBox alignment="CENTER" spacing="16" styleClass="auth-card">
                <HBox alignment="CENTER" spacing="8">
                    <Region styleClass="accent-dot"/>
                    <Label text="IgirePay" styleClass="brand-title"/>
                </HBox>
                <Label text="Create your account in minutes" styleClass="brand-tagline"/>

                <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                    <Label text="Register" styleClass="page-title"/>
                    <Label text="All fields are required" styleClass="page-subtitle"/>
                </VBox>

                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="100" halignment="LEFT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>

                    <Label text="Full name" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="fullNameField"
                               promptText="Your full name"
                               styleClass="form-field"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Email" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="emailField"
                               promptText="you@email.com"
                               styleClass="form-field"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Phone" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="phoneField"
                               promptText="0781234567"
                               styleClass="form-field"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Create PIN" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="pinField"
                                   promptText="5 digits"
                                   styleClass="form-field"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Confirm PIN" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="confirmPinField"
                                   promptText="Re-enter PIN"
                                   styleClass="form-field"
                                   GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label fx:id="errorLabel"
                           styleClass="error-label"
                           wrapText="true"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="0"
                           GridPane.columnSpan="2"/>
                </GridPane>

                <Button text="Create Account"
                        onAction="#handleRegister"
                        styleClass="btn-primary"
                        maxWidth="Infinity"/>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Already registered?" styleClass="footer-text"/>
                    <Button text="Sign in"
                            onAction="#handleGoToLogin"
                            styleClass="btn-link"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
