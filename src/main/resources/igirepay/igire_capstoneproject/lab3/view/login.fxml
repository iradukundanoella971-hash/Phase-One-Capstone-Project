<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="igirepay.igire_capstoneproject.lab3.controller.LoginController"
           styleClass="app-background"
           prefWidth="440" prefHeight="720">

    <ScrollPane fitToWidth="true" styleClass="auth-scroll" hbarPolicy="NEVER">
        <VBox alignment="CENTER" spacing="0">
            <padding>
                <Insets top="40" right="24" bottom="40" left="24"/>
            </padding>

            <VBox alignment="CENTER" spacing="20" styleClass="auth-card">
                <HBox alignment="CENTER" spacing="8">
                    <Region styleClass="accent-dot"/>
                    <Label text="IgirePay" styleClass="brand-title"/>
                </HBox>
                <Label text="Secure mobile banking" styleClass="brand-tagline"/>

                <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                    <Label text="Welcome back" styleClass="page-title"/>
                    <Label text="Sign in with your phone number and PIN" styleClass="page-subtitle"/>
                </VBox>

                <GridPane hgap="12" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="100" halignment="LEFT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>

                    <Label text="Phone" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="phoneField"
                               promptText="e.g. 0781234567"
                               styleClass="form-field"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="PIN" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="pinField"
                                   promptText="5-digit PIN"
                                   styleClass="form-field"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label fx:id="errorLabel"
                           styleClass="error-label"
                           wrapText="true"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="0"
                           GridPane.columnSpan="2"/>
                </GridPane>

                <Button text="Sign In"
                        onAction="#handleLogin"
                        styleClass="btn-primary"
                        maxWidth="Infinity"/>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="New to IgirePay?" styleClass="footer-text"/>
                    <Button text="Create account"
                            onAction="#handleGoToRegister"
                            styleClass="btn-link"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
